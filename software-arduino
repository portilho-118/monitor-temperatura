// ── Tela 1: TEMPERATURA ──────────────────────────────────────
// Termômetro gráfico à esquerda, valor grande à direita,
// badge de nível no topo. Apenas temperatura do objeto.
void telaTemperatura(float tempObj, int nivel) {
  display.clearDisplay();

  // Título
  display.setTextSize(1);
  display.setCursor(0, 0);
  display.print("TEMPERATURA");

  // Badge de nível (canto superior direito)
  String lbl = labelTemperatura(nivel);
  int lblX   = 128 - (lbl.length() * 6) - 1;
  if (nivel == 0) {
    display.setCursor(lblX, 0);
    display.print(lbl);
  } else {
    display.fillRect(lblX - 2, 0, (lbl.length() * 6) + 3, 9, SSD1306_WHITE);
    display.setTextColor(SSD1306_BLACK);
    display.setCursor(lblX, 1);
    display.print(lbl);
    display.setTextColor(SSD1306_WHITE);
  }

  display.drawLine(0, 10, 127, 10, SSD1306_WHITE);

  // Termômetro gráfico (lado esquerdo)
  const int TX = 4;
  const int TY = 13;
  const int TH = 44;
  const int TW = 10;

  display.drawRect(TX, TY, TW + 2, TH, SSD1306_WHITE);
  display.drawCircle(TX + (TW / 2) + 1, TY + TH + 4, 5, SSD1306_WHITE);

  float pct = constrain(tempObj / TEMP_PERIGO, 0.0, 1.0);
  int   barH = (int)(pct * (TH - 2));
  if (barH > 0) {
    display.fillRect(TX + 1, TY + TH - 1 - barH, TW, barH, SSD1306_WHITE);
    display.fillCircle(TX + (TW / 2) + 1, TY + TH + 4, 4, SSD1306_WHITE);
  }

  // Marcas dos limites no termômetro
  auto marcaY = [&](float limite) {
    int y = TY + TH - 1 - (int)(constrain(limite / TEMP_PERIGO, 0.0, 1.0) * (TH - 2));
    display.drawLine(TX + TW + 2, y, TX + TW + 5, y, SSD1306_WHITE);
  };
  marcaY(TEMP_ATENCAO);
  marcaY(TEMP_CRITICO);

  // Valor principal — centralizado no espaço direito
  display.setTextSize(3);
  String valStr = String((int)round(tempObj));
  int vW = valStr.length() * 18;
  int vX = 22 + ((105 - vW) / 2);
  int vY = 13 + ((50 - 24) / 2);
  display.setCursor(vX, vY);
  display.print(valStr);

  // °C ao lado
  display.setTextSize(2);
  display.setCursor(vX + vW + 2, vY);
  display.print("\xB0""C");

  display.display();
}

// ── Tela 2: VIBRAÇÃO ─────────────────────────────────────────
// Valores numéricos X/Y/Z + Zona ISO em quadrado com borda dupla
void telaVibracao(float vX, float vY, float vZ, String zona) {
  display.clearDisplay();

  // Título
  display.setTextSize(1);
  display.setCursor(0, 0);
  display.print("VIBRACAO  mm/s RMS");
  display.drawLine(0, 10, 127, 10, SSD1306_WHITE);

  // Valores numéricos (coluna esquerda, fonte 2)
  int   yLinha[3]   = { 14, 30, 46 };
  float vals[3]     = { vX, vY, vZ };
  const char* eixos[3] = { "X", "Y", "Z" };

  for (int i = 0; i < 3; i++) {
    display.setTextSize(1);
    display.setCursor(0, yLinha[i] + 4);
    display.print(eixos[i]);
    display.print(":");

    display.setTextSize(2);
    display.setCursor(16, yLinha[i]);
    char buf[8];
    dtostrf(vals[i], 4, 2, buf);
    display.print(buf);
  }

  // Quadrado vazado com borda dupla — Zona ISO
  const int QX = 88;
  const int QY = 14;
  const int QS = 38;

  display.drawRect(QX,     QY,     QS,     QS,     SSD1306_WHITE);
  display.drawRect(QX + 1, QY + 1, QS - 2, QS - 2, SSD1306_WHITE);

  // Letra da zona — fonte 4 (24x32px), centralizada no quadrado
  display.setTextSize(4);
  int letraX = QX + (QS - 24) / 2;
  int letraY = QY + (QS - 32) / 2;
  display.setCursor(letraX, letraY);
  display.print(zona);

  // Descrição abaixo do quadrado
  display.setTextSize(1);
  String desc  = descricaoZona(zona);
  int    descX = QX + (QS - (int)(desc.length() * 6)) / 2;
  display.setCursor(max(descX, QX), QY + QS + 2);
  display.print(desc);

  display.display();
}

// ── Tela 3: WIFI ─────────────────────────────────────────────
// Sem ícone. ONLINE/OFFLINE em fonte 2. SSID e IP em fonte 1.
void telaWiFiStatus() {
  display.clearDisplay();

  display.setTextSize(1);
  display.setCursor(0, 0);
  display.print("CONEXAO");
  display.drawLine(0, 10, 127, 10, SSD1306_WHITE);

  bool conectado = (WiFi.status() == WL_CONNECTED);

  if (conectado) {
    display.setTextSize(2);
    display.setCursor(0, 14);
    display.print("ONLINE");

    display.setTextSize(1);
    display.setCursor(0, 34);
    display.print("Rede: ");
    display.print(WiFi.SSID());

    display.setCursor(0, 46);
    display.print("IP: ");
    display.print(WiFi.localIP());
  } else {
    display.setTextSize(2);
    display.setCursor(0, 14);
    display.print("OFFLINE");

    display.setTextSize(1);
    display.setCursor(0, 36);
    display.print("Sem conexao");
    display.setCursor(0, 48);
    display.print("com a rede");
  }

  display.display();
}

// ── Tela 4: BATERIA ──────────────────────────────────────────
// Barra horizontal + percentual grande.
// Hardware pendente: divisor de tensão em A0.
void telaBateria() {
  display.clearDisplay();

  display.setTextSize(1);
  display.setCursor(0, 0);
  display.print("BATERIA");
  display.drawLine(0, 10, 127, 10, SSD1306_WHITE);

  int pct = lerBateria();

  if (pct < 0) {
    // Hardware ainda não conectado
    display.setTextSize(1);
    display.setCursor(14, 22);
    display.print("Sensor nao");
    display.setCursor(14, 34);
    display.print("conectado");
    display.setCursor(14, 48);
    display.print("(em breve)");
  } else {
    // Percentual em fonte grande
    display.setTextSize(3);
    int numX = pct == 100 ? 28 : pct >= 10 ? 36 : 52;
    display.setCursor(numX, 14);
    display.print(pct);
    display.setTextSize(2);
    display.setCursor(numX + (pct == 100 ? 54 : pct >= 10 ? 36 : 18), 20);
    display.print("%");

    // Barra gráfica de bateria
    const int BX = 8, BY = 46, BW = 106, BH = 12;
    display.drawRect(BX, BY, BW, BH, SSD1306_WHITE);
    display.fillRect(BX + BW, BY + 3, 4, 6, SSD1306_WHITE); // terminal +
    int fill = (int)(pct / 100.0 * (BW - 2));
    if (fill > 0)
      display.fillRect(BX + 1, BY + 1, fill, BH - 2, SSD1306_WHITE);

    // Aviso bateria fraca
    if (pct <= 20) {
      display.setTextSize(1);
      display.setCursor(22, BY + 2);
      display.setTextColor(SSD1306_BLACK);
      display.print("BATERIA FRACA");
      display.setTextColor(SSD1306_WHITE);
    }
  }

  display.display();
}

