void telaTemperatura(float tempObj, int nivel) {
  display.clearDisplay();

  display.setTextSize(1);
  display.setCursor(0, 0);
  display.print("TEMPERATURA");

  String lbl = labelTemperatura(nivel);
  int lblX   = 128 - (lbl.length() * 6) - 1;
  if (nivel == 0) {
    display.setCursor(lblX, 0);
    display.print(lbl);
  } else {
    display.fillRect(lblX - 2, 0, (lbl.length() * 6) + 3, 9, SSD1306_WHITE);
    display.setTextColor(SSD1306_BLACK);
    display.setCursor(lblX, 1);
    display.print(lbl);
    display.setTextColor(SSD1306_WHITE);
  }

  display.drawLine(0, 10, 127, 10, SSD1306_WHITE);

  // Ícone termômetro estático
  const int TX = 7;
  const int TY = 14;
  display.drawRect(TX - 2, TY,     5, 30, SSD1306_WHITE);
  display.drawRect(TX - 1, TY + 1, 3, 28, SSD1306_WHITE);
  display.fillRect(TX - 1, TY + 10, 3, 19, SSD1306_WHITE);
  display.fillCircle(TX, TY + 33, 6, SSD1306_WHITE);
  display.drawCircle(TX, TY + 33, 7, SSD1306_WHITE);
  display.drawLine(TX + 3, TY + 6,  TX + 6, TY + 6,  SSD1306_WHITE);
  display.drawLine(TX + 3, TY + 15, TX + 6, TY + 15, SSD1306_WHITE);
  display.drawLine(TX + 3, TY + 24, TX + 6, TY + 24, SSD1306_WHITE);

  display.setTextSize(3);
  String valStr = String((int)round(tempObj));
  int vW = valStr.length() * 18;
  int vX = 28 + ((100 - vW) / 2);
  int vY = 18;
  display.setCursor(vX, vY);
  display.print(valStr);

  display.setTextSize(2);
  int cX = 28 + ((100 - 24) / 2);
  display.setCursor(cX, vY + 28);
  display.print("\xB0""C");

  display.display();
}

void telaVibracao(float vX, float vY, float vZ, String zona) {
  display.clearDisplay();

  display.setTextSize(1);
  display.setCursor(0, 0);
  display.print("VIBRACAO  mm/s RMS");
  display.drawLine(0, 10, 127, 10, SSD1306_WHITE);

  int   yLinha[3]      = { 14, 30, 46 };
  float vals[3]        = { vX, vY, vZ };
  const char* eixos[3] = { "X", "Y", "Z" };

  for (int i = 0; i < 3; i++) {
    display.setTextSize(1);
    display.setCursor(0, yLinha[i] + 4);
    display.print(eixos[i]);
    display.print(":");
    display.setTextSize(2);
    display.setCursor(16, yLinha[i]);
    char buf[8];
    dtostrf(vals[i], 4, 2, buf);
    display.print(buf);
  }

  const int QX = 88;
  const int QY = 14;
  const int QS = 38;
  display.drawRect(QX,     QY,     QS,     QS,     SSD1306_WHITE);
  display.drawRect(QX + 1, QY + 1, QS - 2, QS - 2, SSD1306_WHITE);

  display.setTextSize(4);
  display.setCursor(QX + (QS - 24) / 2, QY + (QS - 32) / 2);
  display.print(zona);

  display.setTextSize(1);
  String desc  = descricaoZona(zona);
  int    descX = QX + (QS - (int)(desc.length() * 6)) / 2;
  display.setCursor(max(descX, QX), QY + QS + 2);
  display.print(desc);

  display.display();
}

void telaWiFiStatus() {
  display.clearDisplay();

  display.setTextSize(1);
  display.setCursor(0, 0);
  display.print("CONEXAO");
  display.drawLine(0, 10, 127, 10, SSD1306_WHITE);

  bool conectado = (WiFi.status() == WL_CONNECTED);

  if (conectado) {
    display.setTextSize(2);
    display.setCursor(0, 14);
    display.print("ONLINE");
    display.setTextSize(1);
    display.setCursor(0, 34);
    display.print("Rede: ");
    display.print(WiFi.SSID());
    display.setCursor(0, 46);
    display.print("IP: ");
    display.print(WiFi.localIP());
  } else {
    display.setTextSize(2);
    display.setCursor(0, 14);
    display.print("OFFLINE");
    display.setTextSize(1);
    display.setCursor(0, 36);
    display.print("Sem conexao");
    display.setCursor(0, 48);
    display.print("com a rede");
  }

  display.display();
}

